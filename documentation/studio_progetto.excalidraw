    {
      "id": "OuXoZOEeMQMU9IKAyMpDx",
      "type": "text",
      "x": -2949.9636967811102,
      "y": -963.5135207570495,
      "width": 517.9835205078125,
      "height": 240,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bWA",
      "roundness": null,
      "seed": 872938412,
      "version": 1123,
      "versionNonce": 41644588,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779866333551,
      "link": null,
      "locked": false,
      "text": "[]INFO[]:\n1)Logica passaggio stato coerente\n2)Stati anche negativi\n3)Selezione corriere automatica (quello con meno spedizioni attive)\n4)Costo dipdendente da un criterio (come km,peso,ecc...)\n5) stima della data di consegna dipendente da un criterio\n6)utente puo vedere i dati della spedizione grazei a un codice\n7)admin vede totale spedizioni, spedizioni in corso, corrieri attivi,\ncreare e gestire nuovi pacchi e corrieri anche tramite filtri\n\n\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "[]INFO[]:\n1)Logica passaggio stato coerente\n2)Stati anche negativi\n3)Selezione corriere automatica (quello con meno spedizioni attive)\n4)Costo dipdendente da un criterio (come km,peso,ecc...)\n5) stima della data di consegna dipendente da un criterio\n6)utente puo vedere i dati della spedizione grazei a un codice\n7)admin vede totale spedizioni, spedizioni in corso, corrieri attivi,\ncreare e gestire nuovi pacchi e corrieri anche tramite filtri\n\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
